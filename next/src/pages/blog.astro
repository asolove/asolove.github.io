---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { postPath, sortByDate } from '../lib/post-helpers';

const posts = sortByDate(await getCollection('posts'));

const dayMonthFmt = new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short' });
const formatDayMonth = (d: Date) => dayMonthFmt.format(d);

type Group = { year: number; posts: typeof posts };
const byYear: Group[] = [];
for (const post of posts) {
  const year = post.data.date.getUTCFullYear();
  const last = byYear[byYear.length - 1];
  if (last && last.year === year) last.posts.push(post);
  else byYear.push({ year, posts: [post] });
}
---
<Base title="Archive" description="All posts on adamsolove.com, in reverse chronological order." current="essays">
  <div class="page no-sidebar">
    <div class="titleblock">
      <h1>Archive</h1>
      <p class="standfirst">Every post on the site, newest first.</p>
    </div>

    <article class="body archive">
      {byYear.map((group) => (
        <section class="year-group">
          <h2 class="year-head" id={String(group.year)}>{group.year}</h2>
          <ul class="year-list">
            {group.posts.map((post) => (
              <li class="entry">
                <time class="entry-date" datetime={post.data.date.toISOString()}>
                  {formatDayMonth(post.data.date)}
                </time>
                <div class="entry-body">
                  <a class="entry-title" href={postPath(post)}>{post.data.title}</a>
                  {post.data.description && (
                    <p class="entry-desc">{post.data.description}</p>
                  )}
                </div>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </article>
  </div>
</Base>

<style>
  .body.archive > .year-group {
    grid-column: 2 / -1;
    max-width: none;
    margin-bottom: 2rem;
  }

  .body.archive .year-head {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 1.6rem;
    line-height: 1.2;
    margin: 1.4rem 0 0.6rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--rule);
    font-variation-settings: "opsz" 32;
  }
  .body.archive .year-group:first-child .year-head { margin-top: 0; }

  .body.archive .year-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .body.archive .entry {
    display: grid;
    grid-template-columns: 5em 1fr;
    gap: 0 1.2rem;
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--rule-soft);
    align-items: baseline;
  }
  .body.archive .entry:last-child { border-bottom: none; }

  .body.archive .entry-date {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--spot);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding-top: 0.15rem;
  }

  .body.archive .entry-body { min-width: 0; }

  .body.archive .entry-title {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 1.15rem;
    line-height: 1.3;
    color: var(--ink);
    border-bottom: 1px solid var(--spot);
    font-variation-settings: "opsz" 24;
  }
  .body.archive .entry-title:hover { background: var(--spot-wash); }

  .body.archive .entry-desc {
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0.25rem 0 0;
    max-width: 38rem;
    font-variation-settings: "opsz" 22;
  }

  @media (max-width: 640px) {
    .body.archive .entry {
      grid-template-columns: 4em 1fr;
      gap: 0 0.8rem;
    }
  }
</style>
