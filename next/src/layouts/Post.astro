---
import Base from './Base.astro';
import { tagLabel, postPath, readingTime } from '../lib/post-helpers';
import type { CollectionEntry, MarkdownHeading } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  headings: MarkdownHeading[];
  prev?: CollectionEntry<'posts'>;
  next?: CollectionEntry<'posts'>;
}

const { post, headings, prev, next } = Astro.props;
const { title, description, date, tags, companion, related_to, dropcap } = post.data;

// Breadcrumb: Blog / <tag> when there's just one; Blog / {tag1, tag2}
// when there are several. The set-syntax variant is rendered by
// Base.astro when the entry has a `tags` field.
const tagCrumb =
  tags && tags.length === 1
    ? { label: tagLabel(tags[0]), href: `/tags/${tags[0]}` }
    : tags && tags.length > 1
    ? { tags: tags.map((t) => ({ label: tagLabel(t), href: `/tags/${t}` })) }
    : null;
const breadcrumb = [
  { label: 'Blog', href: '/blog.html' },
  ...(tagCrumb ? [tagCrumb] : []),
];

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
const formatShortDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' });
const formatYear = (d: Date) => d.getFullYear();

const minutes = readingTime(post.body ?? '');
// Suppress reading-time on short posts (talk announcements, link posts, etc).
const showReadingTime = minutes >= 2;
// Drop-cap looks unbalanced on short pieces; only apply on real long-form.
// `dropcap: false` in frontmatter is an explicit opt-out (use when the
// first paragraph is a parenthetical aside or other bad target).
const isLongForm = (post.body?.split(/\s+/).length ?? 0) > 800;
const useDropcap = isLongForm && dropcap !== false;

// Filter the auto-generated TOC: only h2 and h3. h4s get noisy on
// posts with deep section structure. Each item carries its depth so
// the sidebar can indent visually.
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
const hasSidebar = toc.length > 0 || (companion && companion.length > 0);
---
<Base
  title={title}
  description={description}
  breadcrumb={breadcrumb}
  date={date}
  current="blog"
>
  <div class:list={['page', !hasSidebar && 'no-sidebar']}>

    <div class="titleblock">
      <h1>{title}</h1>
      {description && <p class="standfirst">{description}</p>}
    </div>

    {hasSidebar && (
      <aside class="siderail">
        {/* Mobile disclosure: hidden on wide screens via CSS; on narrow,
            the siderail collapses to just a "Contents ▾" bar that toggles
            the list open. CSS-only via the hidden checkbox. */}
        <input type="checkbox" id="siderail-toggle" class="siderail-toggle" hidden />
        <label class="siderail-summary" for="siderail-toggle">
          <span class="siderail-caret" aria-hidden="true">▶</span>
          <span>Contents</span>
        </label>
        <div class="siderail-body">
        {toc.length > 0 && (
          <>
            <h3>Contents</h3>
            <ul>
              {toc.map((h) => (
                <li class={`toc-d${h.depth}`}><a href={`#${h.slug}`}>{h.text}</a></li>
              ))}
            </ul>
          </>
        )}

        {companion && companion.length > 0 && (
          <>
            <h3>Companion</h3>
            <ul>
              {companion.map((c) => (
                <li><a href={c.url}>▸ {c.label}</a></li>
              ))}
            </ul>
          </>
        )}
        </div>
      </aside>
    )}

    <div class="meta">
      <span><strong>By</strong> Adam Solove</span>
      <span class="sep">·</span>
      <span><strong>Published</strong> {formatDate(date)}</span>
      {showReadingTime && (<>
        <span class="sep">·</span>
        <span><strong>Reading time</strong> {minutes} min</span>
      </>)}
      {related_to && (<>
        <span class="sep">·</span>
        <span><strong>Companion to</strong> {related_to}</span>
      </>)}
    </div>

    <article class:list={['body', isLongForm && 'longform', useDropcap && 'has-dropcap']}>
      <slot />
    </article>

    <footer class="docfoot">
      {prev ? (
        <a href={postPath(prev)} class="nav-prev">
          <span class="label">← Previous</span>
          <span class="title-link">{prev.data.title}</span>
          <span class="nav-date">{formatShortDate(prev.data.date)}</span>
        </a>
      ) : <span class="nav-prev" />}
      {next ? (
        <a href={postPath(next)} class="nav-next">
          <span class="label">Next →</span>
          <span class="title-link">{next.data.title}</span>
          <span class="nav-date">{formatShortDate(next.data.date)}</span>
        </a>
      ) : <span class="nav-next" />}
      <div class="colophon">
        <span class="cite">Cite as: Solove, A. <em>{title}</em>. adamsolove.com, {formatYear(date)}.</span>
        <span class="reply">Comments or questions? <a href="mailto:asolove@gmail.com">asolove@gmail.com</a></span>
      </div>
    </footer>

  </div>
</Base>

<script>
  // Auto-close the mobile contents disclosure when:
  //   - the user clicks a link inside the TOC (so the page can scroll
  //     to the anchor without the open dropdown covering content)
  //   - the user clicks anywhere outside the siderail
  const toggle = document.getElementById('siderail-toggle') as HTMLInputElement | null;
  if (toggle) {
    document.querySelectorAll<HTMLAnchorElement>('.siderail-body a').forEach((a) => {
      a.addEventListener('click', () => { toggle.checked = false; });
    });
    document.addEventListener('click', (e) => {
      if (!toggle.checked) return;
      const t = e.target as Element | null;
      if (t && !t.closest('.siderail')) toggle.checked = false;
    });
  }
</script>
