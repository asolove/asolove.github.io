---
import '../styles/post.css';

interface Props {
  title: string;
  description?: string;
  breadcrumb?: Array<{ label: string; href?: string }>;
  date?: Date;
  current?: 'essays' | 'notes' | 'work';
}

const { title, description, breadcrumb = [], date, current = 'essays' } = Astro.props;

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{title} — Adam Solove</title>
{description && <meta name="description" content={description} />}
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400;1,8..60,600&family=Hanken+Grotesk:wght@400;500;600;700&family=Fragment+Mono&display=swap" rel="stylesheet">
<link rel="alternate" type="application/rss+xml" title="All posts" href="/atom.xml" />
<link rel="icon" href="/img/favicon.png" />
</head>
<body>
<div class="topbar">
  <a class="brand" href="/">
    <span class="name">Adam Solove</span>
  </a>
  <nav>
    <a href="/" class={current === 'essays' ? 'current' : ''}>Essays</a>
    <a href="/notes" class={current === 'notes' ? 'current' : ''}>Notes</a>
    <a href="/work" class={current === 'work' ? 'current' : ''}>Work</a>
    <a href="/atom.xml">RSS</a>
  </nav>
</div>

{breadcrumb.length > 0 && (
  <div class="crumb">
    <div class="path">
      {breadcrumb.map((c, i) => (
        <>
          {i > 0 && <span class="sep">/</span>}
          {i === breadcrumb.length - 1
            ? <em>{c.label}</em>
            : c.href ? <a href={c.href}>{c.label}</a> : <span>{c.label}</span>}
        </>
      ))}
    </div>
    {date && <div class="date">{formatDate(date)}</div>}
  </div>
)}

<slot />
</body>
</html>
