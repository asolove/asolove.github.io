---
import Base from "../layouts/Base.astro";
import {
  postPath,
  sortByDate,
  tagLabel,
  getVisiblePosts,
} from "../lib/post-helpers";

const posts = sortByDate(await getVisiblePosts());

const dayMonthFmt = new Intl.DateTimeFormat("en-GB", {
  day: "2-digit",
  month: "short",
});
const formatDayMonth = (d: Date) => dayMonthFmt.format(d);

type Group = { year: number; posts: typeof posts };
const byYear: Group[] = [];
for (const post of posts) {
  const year = post.data.date.getUTCFullYear();
  const last = byYear[byYear.length - 1];
  if (last && last.year === year) last.posts.push(post);
  else byYear.push({ year, posts: [post] });
}

// Tags with counts, sorted by label.
const counts = new Map<string, number>();
for (const post of posts) {
  for (const t of post.data.tags ?? []) counts.set(t, (counts.get(t) ?? 0) + 1);
}
const tagsForSidebar = [...counts.entries()]
  .map(([slug, count]) => ({ slug, label: tagLabel(slug), count }))
  .sort((a, b) => a.label.localeCompare(b.label));
---
<Base
  title="Blog"
  description="All posts on adamsolove.com, in reverse chronological order."
  current="blog"
>
  <div class="page">
    <div class="titleblock">
      <h1>Blog</h1>
      <p class="standfirst">Every post on the site, newest first.</p>
    </div>

    <aside class="siderail">
      <input
        type="checkbox"
        id="siderail-toggle"
        class="siderail-toggle"
        hidden
      />
      <label class="siderail-summary" for="siderail-toggle">
        <span class="siderail-caret" aria-hidden="true">▶</span>
        <span>Contents</span>
      </label>
      <div class="siderail-body">
        <h3>By tag</h3>
        <ul>
          {tagsForSidebar.map((t) => (
            <li>
              <a href={`/tags/${t.slug}`}>{t.label}</a>
              <span class="cat-count"> ({t.count})</span>
            </li>
          ))}
        </ul>

        <h3>By year</h3>
        <ul>
          {byYear.map((g) => <li><a href={`#${g.year}`}>{g.year}</a></li>)}
        </ul>
      </div>
    </aside>

    <article class="body archive">
      {byYear.map((group) => (
        <section class="year-group">
          <h2 class="year-head" id={String(group.year)}>{group.year}</h2>
          <ul class="year-list">
            {group.posts.map((post) => (
              <li class="entry">
                <time
                  class="entry-date"
                  datetime={post.data.date.toISOString()}
                >
                  {formatDayMonth(post.data.date)}
                </time>
                <div class="entry-body">
                  <a
                    class="entry-title"
                    href={postPath(post)}
                  >{post.data.title}</a>
                  {post.data.description && (
                    <p class="entry-desc">{post.data.description}</p>
                  )}
                </div>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </article>
  </div>
</Base>

<script>
// Auto-close the mobile contents disclosure on link clicks / outside clicks.
const toggle = document.getElementById(
  "siderail-toggle",
) as HTMLInputElement | null;
if (toggle) {
  document
    .querySelectorAll<HTMLAnchorElement>(".siderail-body a")
    .forEach((a) => {
      a.addEventListener("click", () => {
        toggle.checked = false;
      });
    });
  document.addEventListener("click", (e) => {
    if (!toggle.checked) return;
    const t = e.target as Element | null;
    if (t && !t.closest(".siderail")) toggle.checked = false;
  });
}
</script>

<style>
/* Listings sit flush-left in the content area (col 1) and stop at col
   8, leaving col 9 as breathing room before the contents siderail at
   cols 10-12. */
.body.archive > .year-group {
  grid-column: 1 / span 8;
  max-width: none;
  margin-bottom: 2rem;
}

.body.archive .year-head {
  font-family: var(--sans);
  font-weight: 600;
  font-size: 1.6rem;
  line-height: 1.2;
  margin: 1.4rem 0 0.6rem;
  padding-bottom: 0.4rem;
  border-bottom: 1px solid var(--rule);
  font-variation-settings: "opsz" 32;
}
.body.archive .year-group:first-child .year-head {
  margin-top: 0;
}

.body.archive .year-list {
  list-style: none;
  margin: 0;
  padding: 0;
}

.body.archive .entry {
  display: grid;
  grid-template-columns: 5em 1fr;
  gap: 0 1.2rem;
  padding: 0.7rem 0;
  border-bottom: 1px solid var(--rule-soft);
  align-items: baseline;
}
.body.archive .entry:last-child {
  border-bottom: none;
}

.body.archive .entry-date {
  font-family: var(--mono);
  font-size: 0.75rem;
  color: var(--spot);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding-top: 0.15rem;
}

.body.archive .entry-body {
  min-width: 0;
}

.body.archive .entry-title {
  font-family: var(--sans);
  font-weight: 600;
  font-size: 1.15rem;
  line-height: 1.3;
  color: var(--ink);
  border-bottom: 1px solid var(--spot);
  font-variation-settings: "opsz" 24;
}
.body.archive .entry-title:hover {
  background: var(--spot-wash);
}

.body.archive .entry-desc {
  font-family: var(--sans);
  font-style: italic;
  font-size: 0.95rem;
  line-height: 1.5;
  color: var(--ink-soft);
  margin: 0.25rem 0 0;
  max-width: 38rem;
  font-variation-settings: "opsz" 22;
}

/* Category-count chip in the sidebar list. */
.siderail .cat-count {
  color: var(--ink-faint);
  font-feature-settings: "tnum" 1;
}

@media (max-width: 640px) {
  .body.archive .entry {
    grid-template-columns: 4em 1fr;
    gap: 0 0.8rem;
  }
}
</style>
