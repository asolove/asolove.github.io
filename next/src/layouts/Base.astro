---
import '../styles/post.css';

type BreadcrumbItem =
  | { label: string; href?: string }
  | { tags: Array<{ label: string; href: string }> };

interface Props {
  title: string;
  description?: string;
  breadcrumb?: Array<BreadcrumbItem>;
  date?: Date;
  current?: 'blog';
}

const { title, description, breadcrumb = [], date, current } = Astro.props;

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{title} — Adam Solove</title>
{description && <meta name="description" content={description} />}
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="alternate" type="application/rss+xml" title="All posts" href="/atom.xml" />
<link rel="icon" href="/img/favicon.png" />
</head>
<body>
<div class="topbar">
  <a class="brand" href="/">
    <span class="name">Adam Solove</span>
  </a>
  <nav>
    <a href="/blog.html" class={current === 'blog' ? 'current' : ''}>Blog</a>
    <a href="/atom.xml">RSS</a>
  </nav>
</div>

{breadcrumb.length > 0 && (
  <div class="crumb">
    <div class="path">
      {breadcrumb.map((c, i) => (
        <>
          {i > 0 && <span class="sep">/</span>}
          {'tags' in c
            ? <span class="tag-list">
                <span class="brace">{'{'}</span>
                {c.tags.map((t, ti) => (
                  <>
                    {ti > 0 && <span class="comma">, </span>}
                    <a href={t.href}>{t.label}</a>
                  </>
                ))}
                <span class="brace">{'}'}</span>
              </span>
            : c.href
            ? <a href={c.href}>{c.label}</a>
            : i === breadcrumb.length - 1
            ? <em>{c.label}</em>
            : <span>{c.label}</span>}
        </>
      ))}
    </div>
    {date && <div class="date">{formatDate(date)}</div>}
  </div>
)}

<slot />
</body>
</html>
